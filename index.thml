          { en: "He paid me <span class='key'>no more than</span> 3,000 yen.", jp: "彼はたったの3,000円しか払わなかった。", note: "no more than〜「（ほんの）〜しか・だけ」= only" },
          { en: "She paid me <span class='key'>no less than</span> 30,000 yen.", jp: "彼女は30,000円もの額を払ってくれた。", note: "no less than〜「〜ほども多く」= as many/much as" },
