    { q: "「私の兄は父と同じくらい背が高い。」を英語にすると？", blank: "My brother is ___ tall ___ my father.", options:["as / as","so / as","as / than","more / than"], answer: 0, exp: "as+原級+as〜「〜と同じくらい…だ」。両方asを使います。" },
    { q: "「この部屋はあの部屋の2倍の大きさだ。」正しいのは？", blank: "", options:["This room is twice as large as that one.","This room is more large than that twice.","This room is as twice large as that one.","This room is two times large than that."], answer: 0, exp: "X times as...as〜「〜のX倍…だ」。2倍はtwice、半分はhalf。" },
    { q: "比較を強調する語として正しいのは？", blank: "This house is ___ larger than mine.", options:["very","much","more","mostly"], answer: 1, exp: "比較級を強調するにはmuch / far / even / stillを使います。veryは比較級には使えません。" },
    { q: "「〜ほど…でない」を表す正しい構造は？", blank: "", options:["less + 原級 + than","not as + 原級 + as","both A and B","the + 比較級, the + 比較級"], answer: 1, exp: "not as[so]+原級+as〜「〜ほど…でない」。less+原級+thanも同じ意味で使えます。" },
    { q: "「できるだけ早く」を英語にすると？", blank: "", options:["as soon as possible","as quickly as much","more soon as possible","so soon as can"], answer: 0, exp: "as...as possible「できるだけ〜」。as...as one canとも言えます。" },
  ],
  l22: [
    { q: "「彼はこの学校で最も速いスプリンターだ。」正しいのは？", blank: "", options:["He is the fastest sprinter in this school.","He is most fast sprinter in this school.","He is the most fast sprinter in this school.","He is faster sprinter than this school."], answer: 0, exp: "最上級は'the + 最上級 + in[of] + 範囲'の形。fastの最上級はfastest。" },
    { q: "「アラスカほど広い州はアメリカにない。」 ___ に入るのは？", blank: "___ state in the US is as large as Alaska.", options:["Not any","No other","Not every","Not one"], answer: 1, exp: "No (other)+単数形...as[so]+原級+as〜「〜ほど…なものはない」= 最上級の意味を表す。" },
    { q: "「〜よりも…なものはない」という最上級の意味を比較級で表す文は？", blank: "Alaska is larger than ___ state in the US.", options:["any","any other","every other","all other"], answer: 1, exp: "比較級+than any other+単数形「他のどの〜よりも…だ」＝最上級の意味を表します。" },
    { q: "最上級を強調するのに使えない語は？", blank: "She is ___ the best singer.", options:["by far","much","very","the very"], answer: 2, exp: "最上級はby far / much / the veryで強調します。veryは単独では使えません（the very+最上級は可）。" },
  ],
  l23: [
    { q: "「ますます〜」を表す表現は？", blank: "The tree is growing ___.", options:["taller and taller","more and more tall","the more tall","much taller"], answer: 0, exp: "比較級+and+比較級「ますます〜」。一音節の比較級はer形を繰り返します。" },
    { q: "「〜すればするほど…」を表す表現の正しい形は？", blank: "", options:["The more I study, the more I know.","More I study, more I know.","As more I study, as more I know.","The more I study, I know more."], answer: 0, exp: "The+比較級..., the+比較級...「〜すればするほど…」" },
    { q: "「そのカメラは手のひらほどの大きさしかない」(=ほんの〜) を表すのは？", blank: "The camera is ___ my hand.", options:["no bigger than","not bigger than","no big as","not as big than"], answer: 0, exp: "A...no+比較級+than B「（ほんの）Bと同程度にしか…でない」" },
    { q: "「30,000円もの額」(= as much as) を表す表現は？", blank: "She paid me ___ 30,000 yen.", options:["no less than","no more than","not less than","not more than"], answer: 0, exp: "no less than〜「〜ほども多く」= as many/much as。not less thanは「少なくとも〜」の意味。" },
  ],
  l24: [
    { q: "「私はボストンに住んでいる友人がいる。」( ___ は人が先行詞・主格)", blank: "I have a friend ___ lives in Boston.", options:["who","which","whom","whose"], answer: 0, exp: "who：先行詞が人で、関係詞節中で主語の働きをする（主格）。" },
    { q: "先行詞が「人以外」で主格の関係代名詞は？", blank: "They live in a house ___ stands on a hill.", options:["which","who","whom","whose"], answer: 0, exp: "which：先行詞が人以外のとき、主格・目的格として使う。" },
    { q: "所有格の関係代名詞は？（先行詞・人/物ともに同じ）", blank: "He has a friend ___ wife is a singer.", options:["whose","who's","which","that"], answer: 0, exp: "whose：所有格の関係代名詞。先行詞が人でも物でもwhoseを使う。" },
    { q: "目的格の関係代名詞で省略できないものは？", blank: "", options:["前置詞の目的語でない目的格のwho(m)","whoの目的格","whichの目的格","前置詞の直後に置かれたwhich"], answer: 3, exp: "前置詞の直後（前置詞+which/whom）は省略できません。前置詞を後ろに置けば省略可能です。" },
    { q: "thatが特に好まれる先行詞はどれ？", blank: "", options:["the only book","a book","some books","any book"], answer: 0, exp: "the first, the last, the+最上級, the same, the onlyなど特定の1つであることを表す修飾語を伴う場合はthatが好まれる。" },
  ],
  l25: [
    { q: "whatの正しい説明は？", blank: "", options:["先行詞を含む関係代名詞で「〜すること[もの]」を意味する","先行詞が人のときだけ使う","先行詞が物のときだけ使う","継続用法にのみ使う"], answer: 0, exp: "what = the thing(s) that〜。先行詞を含む関係代名詞で、先行詞なしで使います。" },
    { q: "継続用法でthatを使えるのは？", blank: "", options:["使えない（thatは継続用法不可）","コンマがあるときは使える","先行詞が人以外のとき使える","どんな場合でも使える"], answer: 0, exp: "thatは継続用法には使えません。継続用法にはwho/which（コンマあり）を使います。" },
    { q: "前置詞を関係詞節の前に出す場合、( ___ )に入るのは？", blank: "He is the actor to ___ Ann sent a fan letter.", options:["whom","who","that","which"], answer: 0, exp: "前置詞の直後には whom（人）またはwhich（物）のみ使えます。who / that は使えません。" },
    { q: "継続用法のwhichが指せるものは？", blank: "", options:["直前の語句・節・文の内容全体","先行詞（人）のみ","先行詞（物）のみ","直前の文全体のみ"], answer: 0, exp: "継続用法のwhichは(a)直前の語句、(b)直前の節、(c)直前の文の内容全体を先行詞とすることができます。" },
  ],
  l26: [
    { q: "「場所」を表す関係副詞は？", blank: "This is the hospital ___ my aunt works.", options:["where","when","why","how"], answer: 0, exp: "where：「場所」を表す副詞の役割。〈前置詞+which〉で書きかえ可能。" },
    { q: "「〜する（理由）」を表す関係副詞は？", blank: "Tell me the reason ___ you look so happy.", options:["why","where","when","how"], answer: 0, exp: "why：「〜する（理由）」。先行詞はreason(s)。省略されることもある。" },
    { q: "howについて正しい説明は？", blank: "", options:["先行詞なしで使い、the way howとは言えない","先行詞がwayのときだけ使う","the way howでも使える","先行詞が必要な関係副詞"], answer: 0, exp: "how：先行詞なしで使う。×the way how → ○the way (in which) / the way that / how" },
    { q: "「〜する人はだれでも」を意味する複合関係詞は？", blank: "", options:["whoever","whatever","whenever","whichever"], answer: 0, exp: "whoever「〜する人はだれでも」= no matter who。whoever can be replaced with 'anyone who'." },
    { q: "「いつ〜しても」を意味する複合関係詞は？", blank: "I visit my uncle ___ I go to Osaka.", options:["whenever","wherever","whoever","whatever"], answer: 0, exp: "whenever「〜する時はいつも/いつ〜しても」= no matter when。" },
  ],
  l27: [
    { q: "「どれほど疲れていても」を意味する表現は？", blank: "___ tired she is, she always smiles.", options:["However","Whatever","Whoever","Whenever"], answer: 0, exp: "however+形容詞/副詞+S+V「どれほど〜でも」= no matter how。" },
    { q: "「what is called」の意味は？", blank: "", options:["いわゆる〜","〜するもの","現在の〜","まるで〜のように"], answer: 0, exp: "what is called「いわゆる〜」。This music is what is called 'rap.'（これはいわゆるラップという音楽だ。）" },
    { q: "「what is more」の意味は？", blank: "", options:["そのうえ","もっと何か","さらに悪いことに","それどころか"], answer: 0, exp: "what is more「そのうえ」。反対にwhat is worse「さらに悪いことに」もあります。" },
    { q: "「however」を「no matter〜」で言い換えると？", blank: "", options:["no matter how","no matter what","no matter who","no matter which"], answer: 0, exp: "however = no matter how。similarly: whoever=no matter who, whatever=no matter what。" },
  ],
  l28: [
    { q: "仮定法過去の正しい形は？（現在の事実と反対）", blank: "If he ___ ready, we ___ go.", options:["were / would","is / will","had been / would","was being / could"], answer: 0, exp: "仮定法過去：If+S+動詞の過去形（be動詞はwere）, S+would[could/might]+動詞の原形。現在の事実と反対。" },
    { q: "仮定法過去完了の正しい形は？（過去の事実と反対）", blank: "If I ___ earlier, I ___ the train.", options:["had left / would not have missed","left / would not miss","had left / would not miss","left / would not have missed"], answer: 0, exp: "仮定法過去完了：If+S+had+過去分詞, S+would[could/might]+have+過去分詞。過去の事実と反対。" },
    { q: "仮定法で be動詞を使うとき、主語が I や he でも使うのは？", blank: "", options:["were","was","is","be"], answer: 0, exp: "仮定法ではbe動詞は人称・数に関係なくwereを使う（口語では1人称・3人称単数でwasも使われる）。" },
    { q: "「もし〜だったなら（過去）、今ごろ…だろう（現在）」という混合仮定法の形は？", blank: "", options:["If+had+過去分詞, would+原形","If+過去形, would have+過去分詞","If+had+過去分詞, would have+過去分詞","If+過去形, would+原形"], answer: 0, exp: "if節が仮定法過去完了（過去の仮定）+ 主節が仮定法過去（現在の結果）の混合形。" },
  ],
  l29: [
    { q: "「彼女の電話番号を知っていればなあ。」（今現在の願望）", blank: "I wish I ___ her telephone number.", options:["knew","know","had known","would know"], answer: 0, exp: "wish+仮定法過去「〜ならなあ」。願っている時と同時のことは過去形を使います。" },
    { q: "「高いバッグを買わなければよかったなあ。」（過去のことへの後悔）", blank: "I wish I ___ such an expensive bag.", options:["hadn't bought","didn't buy","wouldn't buy","haven't bought"], answer: 0, exp: "wish+仮定法過去完了「〜だったらなあ」。願っている時よりも前のことは過去完了を使います。" },
    { q: "ifの省略による倒置で正しい文は？", blank: "", options:["Were I you, I would ask her.","Was I you, I would ask her.","If were I you, I would ask her.","I were you, I would ask her."], answer: 0, exp: "ifを省略すると後のSVが倒置される。were/had/shouldが文頭に出る形。" },
    { q: "「もし〜するようなことがあれば」（未来・実現可能性低）という意味は？", blank: "If he ___ change his mind, he would call me.", options:["should","would","could","were to"], answer: 0, exp: "If S should do「もし〜するようなことがあれば」。実現可能性が低いことを表す。" },
  ],
  l30: [
    { q: "「夢がなければ」をif節なしで表すと？", blank: "___ dreams, life would have no meaning.", options:["But for","Without / But for","Except for","Despite"], answer: 0, exp: "but for〜「〜がなければ/なかったら」= without〜。どちらも正解ですが選択肢はBut forのみが正確。" },
    { q: "「音楽がなければ、人生は退屈だろう。」正しい表現は？", blank: "", options:["If it were not for music, life would be boring.","If it is not for music, life would be boring.","If it was not for music, life would be boring.","Without music, life is boring."], answer: 0, exp: "if it were not for〜「もし〜がなければ」（現在）。= but for / without。" },
    { q: "「もう〜してもよいころだ」を表す表現は？", blank: "", options:["It's time + 仮定法過去","It's time + 仮定法過去完了","It's time + to不定詞のみ","It's time + 原形"], answer: 0, exp: "It's time+仮定法過去「もう〜してもよいころだ」。It's time you bought a new bicycle.など。" },
    { q: "「もし彼が気が変わったなら（過去の仮定法完了）」ifを省略した形は？", blank: "___ we known you were in the hospital, we would have visited you.", options:["Had","Were","Should","Did"], answer: 0, exp: "had+過去分詞の仮定法過去完了でifを省略すると、Hadが文頭に出る倒置構文になります。" },
    { q: "「それとなく依頼する」最もていねいな表現は？", blank: "", options:["I was wondering if you could help me.","Can you help me?","I wonder if you can help me.","Would you help me?"], answer: 0, exp: "wonderを過去進行形にすると、さらにていねいな表現になります。" },
  ]
};

// =============================================
// STATE
// =============================================
let currentLesson = 'l21';
let quizState = {};
let totalXP = 0;

// =============================================
// RENDER
// =============================================
function showLesson(id) {
  currentLesson = id;
  // update sidebar
  document.querySelectorAll('.lesson-btn').forEach(b => b.classList.remove('active'));
  event.currentTarget.classList.add('active');
  renderLesson(id);
}

function renderLesson(id) {
  const lesson = LESSONS[id];
  const quizzes = QUIZZES[id] || [];

  quizState[id] = quizState[id] || { idx: 0, score: 0, answered: false, finished: false };

  const html = `
    <div class="lesson-card">
      <div class="lesson-header">
        <div class="lesson-label">Lesson ${lesson.num}</div>
        <div class="lesson-title">${lesson.title} <span class="jp">${lesson.jp}</span></div>
        <div class="lesson-desc">${lesson.desc}</div>
      </div>
      <div class="tab-bar">
        <button class="tab-btn active" onclick="switchTab(this,'study-${id}')">📖 解説</button>
        <button class="tab-btn" onclick="switchTab(this,'quiz-${id}')">✏️ 確認テスト</button>
        <button class="tab-btn" onclick="switchTab(this,'ai-${id}')">🤖 AI個別質問</button>
      </div>

      <!-- STUDY TAB -->
      <div class="tab-content active" id="study-${id}">
        ${lesson.sections.map((sec, si) => `
          <div class="grammar-section">
            <div class="grammar-section-title">
              <span class="section-badge">${String.fromCharCode(65+si)}</span>
              ${sec.title}
            </div>
            ${sec.formula ? `<div class="formula-box"><div class="formula-label">構造</div>${sec.formula}</div>` : ''}
            ${sec.points.map(p => `
              <div class="example-block">
                <div class="example-en">${p.en}</div>
                <div class="example-jp">🇯🇵 ${p.jp}</div>
                ${p.note ? `<div class="tip-box">${p.note}</div>` : ''}
              </div>
            `).join('')}
            ${sec.tip ? `<div class="tip-box">${sec.tip}</div>` : ''}
          </div>
        `).join('')}
      </div>

      <!-- QUIZ TAB -->
      <div class="tab-content" id="quiz-${id}">
        ${renderQuiz(id)}
      </div>

      <!-- AI TAB -->
      <div class="tab-content" id="ai-${id}">
        <div class="ai-section checker-area">
          <div class="ai-section-title">🤖 AIに質問する</div>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px;">
            この文法についてわからないことを何でも質問してください。英作文の添削や例文の説明もできます！
          </p>
          <div class="ai-input-row">
            <textarea class="ai-input" id="aiInput-${id}" placeholder="例：「as if の後ろはなぜ過去形を使うの？」「この英文を添削して」など" rows="2"></textarea>
            <button class="ai-btn" onclick="askAI('${id}')">
              <span>送信</span>
              <span>→</span>
            </button>
          </div>
          <div class="ai-loading" id="aiLoading-${id}">
            <div class="dot-pulse"><span></span><span></span><span></span></div>
            <span>AIが回答を考えています...</span>
          </div>
          <div class="ai-response" id="aiResponse-${id}"></div>
        </div>
      </div>
    </div>
  `;
  document.getElementById('mainContent').innerHTML = html;
}

function renderQuiz(id) {
  const qs = QUIZZES[id] || [];
  const state = quizState[id] || { idx: 0, score: 0, answered: false, finished: false };

  if (state.finished) {
    const pct = Math.round((state.score / qs.length) * 100);
    const emoji = pct >= 80 ? '🏆' : pct >= 60 ? '👍' : '💪';
    const msg = pct >= 80 ? '素晴らしい！完璧な理解です！' : pct >= 60 ? 'よくできました！もう一度復習してみよう。' : '復習してもう一度挑戦してみよう！';
    return `
      <div class="result-screen visible">
        <div class="result-emoji">${emoji}</div>
        <div class="result-score">${state.score} / ${qs.length}</div>
        <div class="result-msg">${msg}（正解率 ${pct}%）</div>
        <button class="btn-retry" onclick="retryQuiz('${id}')">🔄 もう一度</button>
        <button class="btn-retry secondary" onclick="switchTabById('study-${id}')">📖 解説を見る</button>
      </div>
    `;
  }

  const q = qs[state.idx];
  const progress = state.idx / qs.length * 100;

  return `
    <div class="quiz-container">
      <div class="quiz-progress">
        <span class="quiz-counter">問 ${state.idx + 1} / ${qs.length}</span>
        <div class="progress-bar-wrap">
          <div class="progress-bar" style="width:${progress}%"></div>
        </div>
        <span class="score-badge">${state.score} 正解</span>
      </div>
      <div class="quiz-card">
        <div class="quiz-q-label">Q${state.idx + 1}</div>
        <div class="quiz-q-text">${q.q}</div>
        ${q.blank ? `<div class="quiz-q-sub" style="font-size:14px;color:#444;margin-bottom:12px;"><em>${q.blank}</em></div>` : ''}
        <div class="quiz-options" id="quizOpts-${id}">
          ${q.options.map((opt, oi) => `
            <button class="quiz-option" onclick="selectAnswer('${id}', ${oi})" id="opt-${id}-${oi}">
              <span class="option-indicator">${String.fromCharCode(65+oi)}</span>
              ${opt}
            </button>
          `).join('')}
        </div>
        <div class="quiz-feedback" id="quizFeedback-${id}"></div>
      </div>
      <div class="quiz-nav">
        <button class="btn-next" id="quizNext-${id}" onclick="nextQuestion('${id}')">
          ${state.idx < qs.length - 1 ? '次の問題 →' : '結果を見る 🎉'}
        </button>
      </div>
    </div>
  `;
}

function selectAnswer(id, oi) {
  const state = quizState[id];
  if (state.answered) return;
  state.answered = true;

  const qs = QUIZZES[id];
  const q = qs[state.idx];
  const correct = q.answer === oi;

  if (correct) {
    state.score++;
    addXP(10);
  }

  // Disable all options
  document.querySelectorAll(`#quizOpts-${id} .quiz-option`).forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.answer) btn.classList.add('correct');
    else if (i === oi && !correct) btn.classList.add('wrong');
  });

  // Show feedback
  const fb = document.getElementById(`quizFeedback-${id}`);
  fb.className = `quiz-feedback ${correct ? 'correct' : 'wrong'} visible`;
  fb.innerHTML = `<strong>${correct ? '✅ 正解！' : '❌ 不正解'}</strong>${q.exp}`;

  // Show next button
  document.getElementById(`quizNext-${id}`).classList.add('visible');
}

function nextQuestion(id) {
  const qs = QUIZZES[id];
  const state = quizState[id];

  if (state.idx < qs.length - 1) {
    state.idx++;
    state.answered = false;
    // Re-render quiz tab content
    const tab = document.getElementById(`quiz-${id}`);
    tab.innerHTML = renderQuiz(id);
  } else {
    state.finished = true;
    state.answered = false;
    const tab = document.getElementById(`quiz-${id}`);
    tab.innerHTML = renderQuiz(id);
  }
}

function retryQuiz(id) {
  quizState[id] = { idx: 0, score: 0, answered: false, finished: false };
  const tab = document.getElementById(`quiz-${id}`);
  tab.innerHTML = renderQuiz(id);
}

function switchTab(btn, tabId) {
  // find all tab-btns and tab-contents in same lesson card
  const card = btn.closest('.lesson-card');
  card.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  card.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(tabId).classList.add('active');
}

function switchTabById(tabId) {
  const tab = document.getElementById(tabId);
  if (!tab) return;
  const card = tab.closest('.lesson-card');
  card.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  card.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  // Find the matching tab-btn
  card.querySelectorAll('.tab-btn').forEach(b => {
    if (b.getAttribute('onclick') && b.getAttribute('onclick').includes(tabId)) {
      b.classList.add('active');
    }
  });
  tab.classList.add('active');
}

// =============================================
// AI
// =============================================
async function askAI(id) {
  const lesson = LESSONS[id];
  const input = document.getElementById(`aiInput-${id}`);
  const loading = document.getElementById(`aiLoading-${id}`);
  const response = document.getElementById(`aiResponse-${id}`);
  const btn = input.closest('.ai-section').querySelector('.ai-btn');

  const question = input.value.trim();
  if (!question) { input.focus(); return; }

  btn.disabled = true;
  loading.classList.add('visible');
  response.classList.remove('visible');
  response.textContent = '';

  const systemPrompt = `あなたは日本人高校生向けの英文法専門の先生です。
今学習中のレッスン：Lesson ${lesson.num} 「${lesson.title}（${lesson.jp}）」

このレッスンのポイント：
${lesson.sections.map(s => s.title + '\n' + s.points.map(p => '  例: ' + p.en.replace(/<[^>]+>/g, '') + ' → ' + p.jp).join('\n')).join('\n\n')}

以下のルールで回答してください：
- 日本語でわかりやすく説明する
- 具体的な英語の例文を必ず使う
- なぜその形になるかの理由も説明する
- 高校生が理解できるよう、専門用語は補足説明する
- 英作文の添削の場合は、誤りを指摘し正しい形と理由を説明する
- 回答は簡潔にまとめる（長すぎない）`;

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: "user", content: question }]
      })
    });
    const data = await res.json();
    const text = data.content?.map(c => c.text || '').join('') || '回答を取得できませんでした。';
    response.textContent = text;
    response.classList.add('visible');
    addXP(5);
  } catch (e) {
    response.textContent = '⚠️ 通信エラーが発生しました。もう一度お試しください。';
    response.classList.add('visible');
  }

  loading.classList.remove('visible');
  btn.disabled = false;
}

function addXP(amount) {
  totalXP += amount;
  document.getElementById('totalXP').textContent = totalXP + ' XP';
}

// =============================================
// INIT
// =============================================
renderLesson('l21');
</script>
</body>
</html>
