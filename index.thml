          { en: "<span class='key'>With</span> time, this project would succeed.", jp: "時間があれば、このプロジェクトは成功するだろう。", note: "with〜「〜があれば/〜があったら」" },
          { en: "I know he is innocent; <span class='key'>otherwise</span> I wouldn't try to save him.", jp: "私は彼が無実だと知っている。そうでなければ彼を助けようとしないだろう。", note: "otherwise「そうでなければ」= if節の代わりになる。" },
          { en: "<span class='key'>To hear</span> him talk, you would think he knew all about the secret.", jp: "彼の話を聞けば、彼が秘密のすべてを知っていると思うだろう。", note: "不定詞がif節の代わりになる。" },
        ]
      },
      {
        title: "B 仮定法を使った慣用表現",
        points: [
          { en: "<span class='key'>If it were not for</span> music, life would be boring.", jp: "音楽がなければ、人生は退屈だろう。", note: "if it were not for〜「もし〜がなければ」（現在）= but for, without" },
          { en: "<span class='key'>If it had not been for</span> my seat belt, I would have been killed.", jp: "シートベルトがなかったら、私は死んでいたろう。", note: "if it had not been for〜「もし〜がなかったら」（過去）" },
          { en: "<span class='key'>It's time</span> you bought a new bicycle.", jp: "もう新しい自転車を買ってもよいころだ。", note: "It's time + 仮定法過去「もう〜してもよいころだ」" },
          { en: "<span class='key'>If only</span> she were here!", jp: "彼女がここにいさえすればなあ！", note: "if only+仮定法「〜でありさえすれば（それだけでいいのに）なあ」= I wish とほぼ同じ意味" },
        ]
      },
      {
        title: "C 仮定法を使ったていねいな表現",
        points: [
          { en: "It <span class='key'>would</span> be nice if you <span class='key'>could help</span> me with my luggage.", jp: "荷物を手伝っていただければ助かるのですが。", note: "仮定法を使うと、ていねいな表現になる。" },
          { en: "I <span class='key'>was wondering</span> if you <span class='key'>could use</span> your phone.", jp: "お電話をお借りできないかと思いまして。", note: "wonder/be wonderingを過去形や進行形にすると、さらにていねいな表現になる。" },
        ],
        tip: "Would you mind if I...? / Could you...? なども仮定法を使ったていねいな表現。相手への遠慮・配慮を表す。"
      }
    ]
  }
};

