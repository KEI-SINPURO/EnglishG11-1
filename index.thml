          { en: "<span class='key'>Had</span> we known you were in the hospital, we would have visited you.", jp: "あなたが入院しているとわかっていたら、お見舞いに行ったのに。" },
          { en: "<span class='key'>Should</span> there be an earthquake, this bookshelf would fall forward.", jp: "もし地震が起きたら、この本棚は前に倒れるだろう。" },
        ],
        formula: "<span class='accent'>Were[Had/Should]</span> + S + ..., S + would ... （ifの省略）"
      }
