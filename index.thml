<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>英文法マスター | Lessons 21–30</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Poppins:wght@400;600;700&display=swap');

  :root {
    --navy: #1a2340;
    --navy-light: #253057;
    --indigo: #3d52a0;
    --sky: #7091e6;
    --sky-light: #8697c4;
    --cream: #f7f8fc;
    --white: #ffffff;
    --gold: #f0a500;
    --gold-light: #ffd580;
    --green: #28a745;
    --red: #dc3545;
    --text-main: #1a2340;
    --text-muted: #6b7a9e;
    --border: #dde3f0;
    --shadow: 0 4px 24px rgba(26,35,64,0.10);
    --shadow-lg: 0 8px 40px rgba(26,35,64,0.16);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: var(--cream);
    color: var(--text-main);
    min-height: 100vh;
  }

  /* ===== HEADER ===== */
  header {
    background: linear-gradient(135deg, var(--navy) 0%, var(--indigo) 100%);
    color: white;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-lg);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: var(--gold);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; color: var(--navy);
    font-family: 'Poppins', sans-serif;
  }
  .logo-text {
    font-family: 'Poppins', sans-serif;
    font-size: 18px; font-weight: 700;
    letter-spacing: 0.5px;
  }
  .logo-sub { font-size: 11px; opacity: 0.7; margin-top: 1px; font-weight: 300; }
  .header-progress {
    display: flex; align-items: center; gap: 10px;
    font-size: 12px; opacity: 0.85;
  }
  .xp-badge {
    background: var(--gold); color: var(--navy);
    padding: 4px 10px; border-radius: 20px;
    font-weight: 700; font-size: 13px;
    font-family: 'Poppins', sans-serif;
  }

  /* ===== MAIN LAYOUT ===== */
  .app-container {
    display: flex;
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 16px;
    gap: 24px;
    align-items: flex-start;
  }

  /* ===== SIDEBAR ===== */
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 72px;
  }
  .sidebar-section {
    background: white;
    border-radius: 16px;
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .sidebar-title {
    background: var(--navy);
    color: white;
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .lesson-btn {
    display: block; width: 100%;
    padding: 10px 16px;
    border: none; background: none;
    text-align: left;
    cursor: pointer;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 13px;
    color: var(--text-main);
    border-left: 3px solid transparent;
    transition: all 0.2s;
    border-bottom: 1px solid var(--border);
    line-height: 1.4;
  }
  .lesson-btn:last-child { border-bottom: none; }
  .lesson-btn:hover { background: #f0f4ff; border-left-color: var(--sky); }
  .lesson-btn.active {
    background: #eef2ff;
    border-left-color: var(--indigo);
    color: var(--indigo);
    font-weight: 700;
  }
  .lesson-btn .lesson-num {
    display: inline-block;
    background: var(--indigo);
    color: white;
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 11px;
    margin-right: 6px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
  }
  .lesson-btn.active .lesson-num { background: var(--gold); color: var(--navy); }

  /* ===== MAIN CONTENT ===== */
  .main-content {
    flex: 1;
    min-width: 0;
  }

  /* ===== LESSON CARD ===== */
  .lesson-card {
    background: white;
    border-radius: 20px;
    box-shadow: var(--shadow);
    overflow: hidden;
    margin-bottom: 20px;
  }
  .lesson-header {
    background: linear-gradient(135deg, var(--navy) 0%, var(--indigo) 100%);
    color: white;
    padding: 20px 24px;
  }
  .lesson-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; opacity: 0.7;
    text-transform: uppercase; font-family: 'Poppins', sans-serif;
    margin-bottom: 4px;
  }
  .lesson-title {
    font-size: 22px; font-weight: 700;
    font-family: 'Poppins', sans-serif;
    display: flex; align-items: center; gap: 10px;
  }
  .lesson-title .jp { font-size: 16px; font-family: 'Noto Sans JP', sans-serif; opacity: 0.85; }
  .lesson-desc {
    font-size: 13px; margin-top: 8px; opacity: 0.8; line-height: 1.6;
  }

  .tab-bar {
    display: flex;
    border-bottom: 2px solid var(--border);
    background: white;
  }
  .tab-btn {
    flex: 1; padding: 12px; border: none; background: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 13px; font-weight: 500;
    color: var(--text-muted); cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s;
  }
  .tab-btn:hover { color: var(--indigo); }
  .tab-btn.active { color: var(--indigo); border-bottom-color: var(--indigo); font-weight: 700; }

  .tab-content { padding: 24px; display: none; }
  .tab-content.active { display: block; }

  /* ===== GRAMMAR POINTS ===== */
  .grammar-section {
    margin-bottom: 24px;
    border-left: 4px solid var(--sky);
    padding-left: 16px;
  }
  .grammar-section-title {
    font-size: 14px; font-weight: 700;
    color: var(--indigo);
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .section-badge {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    background: var(--indigo); color: white;
    border-radius: 50%; font-size: 11px; font-weight: 700;
    font-family: 'Poppins', sans-serif;
  }

  .example-block {
    background: #f8f9ff;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 12px;
    border: 1px solid #e8ecf8;
  }
  .example-en {
    font-size: 14px; font-weight: 500;
    color: var(--navy); line-height: 1.7;
    margin-bottom: 4px;
  }
  .example-en .key {
    color: var(--indigo); font-weight: 700;
    background: #dde8ff; padding: 1px 4px; border-radius: 4px;
  }
  .example-jp {
    font-size: 12px; color: var(--text-muted);
    margin-top: 4px;
  }
  .tip-box {
    background: #fff9e6;
    border: 1px solid #ffd54f;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    color: #5d4a00;
    margin-top: 8px;
    line-height: 1.6;
  }
  .tip-box::before { content: "💡 "; }

  /* ===== FORMULA BOX ===== */
  .formula-box {
    background: var(--navy);
    color: white;
    border-radius: 10px;
    padding: 14px 18px;
    margin: 12px 0;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    line-height: 1.8;
  }
  .formula-box .formula-label {
    font-size: 10px; letter-spacing: 1.5px; opacity: 0.6;
    text-transform: uppercase; margin-bottom: 6px;
  }
  .formula-box .accent { color: var(--gold-light); font-weight: 700; }

  /* ===== AI SECTION ===== */
  .ai-section {
    background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
    border-radius: 16px;
    padding: 20px;
    margin-top: 8px;
    border: 1px solid #d0dafe;
  }
  .ai-section-title {
    font-size: 13px; font-weight: 700;
    color: var(--indigo); margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .ai-input-row {
    display: flex; gap: 10px;
    margin-bottom: 10px;
  }
  .ai-input {
    flex: 1;
    padding: 10px 14px;
    border: 2px solid #c5d0f8;
    border-radius: 10px;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 13px;
    background: white;
    outline: none;
    transition: border 0.2s;
    resize: none;
    min-height: 44px;
  }
  .ai-input:focus { border-color: var(--indigo); }
  .ai-btn {
    padding: 10px 20px;
    background: var(--indigo);
    color: white; border: none; border-radius: 10px;
    font-weight: 700; font-size: 13px; cursor: pointer;
    font-family: 'Noto Sans JP', sans-serif;
    transition: all 0.2s; white-space: nowrap;
    display: flex; align-items: center; gap: 6px;
  }
  .ai-btn:hover { background: var(--navy); transform: translateY(-1px); }
  .ai-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .ai-response {
    background: white;
    border-radius: 10px;
    padding: 14px;
    font-size: 13px;
    line-height: 1.8;
    color: var(--text-main);
    border: 1px solid #d0dafe;
    min-height: 48px;
    white-space: pre-wrap;
    display: none;
  }
  .ai-response.visible { display: block; }
  .ai-loading {
    display: none; align-items: center; gap: 8px;
    font-size: 12px; color: var(--text-muted); padding: 8px 0;
  }
  .ai-loading.visible { display: flex; }
  .dot-pulse span {
    display: inline-block; width: 6px; height: 6px;
    background: var(--sky); border-radius: 50%; margin: 0 2px;
    animation: dotPulse 1.2s infinite;
  }
  .dot-pulse span:nth-child(2) { animation-delay: 0.2s; }
  .dot-pulse span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dotPulse { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

  /* ===== QUIZ ===== */
  .quiz-container { }
  .quiz-progress {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .quiz-counter { font-size: 12px; color: var(--text-muted); font-weight: 500; }
  .progress-bar-wrap {
    flex: 1; height: 8px; background: var(--border);
    border-radius: 10px; margin: 0 14px; overflow: hidden;
  }
  .progress-bar {
    height: 100%; background: linear-gradient(90deg, var(--sky), var(--indigo));
    border-radius: 10px; transition: width 0.4s;
  }
  .score-badge {
    background: var(--gold); color: var(--navy);
    padding: 3px 10px; border-radius: 20px;
    font-size: 12px; font-weight: 700; font-family: 'Poppins', sans-serif;
  }

  .quiz-card {
    background: #f8f9ff;
    border-radius: 14px;
    padding: 22px;
    border: 1px solid var(--border);
    margin-bottom: 16px;
  }
  .quiz-q-label {
    font-size: 10px; letter-spacing: 1.5px; font-weight: 700;
    color: var(--sky); text-transform: uppercase; margin-bottom: 10px;
    font-family: 'Poppins', sans-serif;
  }
  .quiz-q-text {
    font-size: 16px; font-weight: 600; line-height: 1.7;
    color: var(--navy); margin-bottom: 6px;
  }
  .quiz-q-sub {
    font-size: 12px; color: var(--text-muted); margin-bottom: 16px;
  }
  .quiz-options { display: grid; gap: 10px; }
  .quiz-option {
    padding: 12px 16px;
    border: 2px solid var(--border);
    border-radius: 10px;
    background: white;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 14px; cursor: pointer;
    text-align: left;
    transition: all 0.2s;
    display: flex; align-items: center; gap: 10px;
    color: var(--text-main);
  }
  .quiz-option:hover:not(:disabled) { border-color: var(--sky); background: #f0f4ff; }
  .quiz-option.correct { border-color: var(--green); background: #e8f8ed; color: #155724; }
  .quiz-option.wrong { border-color: var(--red); background: #fde8ec; color: #721c24; }
  .quiz-option:disabled { cursor: default; }
  .option-indicator {
    width: 24px; height: 24px;
    border-radius: 50%; border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; flex-shrink: 0;
    font-family: 'Poppins', sans-serif;
    transition: all 0.2s;
    color: var(--text-muted);
  }
  .quiz-option:hover:not(:disabled) .option-indicator { border-color: var(--sky); color: var(--sky); }
  .quiz-option.correct .option-indicator { border-color: var(--green); background: var(--green); color: white; }
  .quiz-option.wrong .option-indicator { border-color: var(--red); background: var(--red); color: white; }

  .quiz-feedback {
    padding: 14px 16px;
    border-radius: 10px;
    font-size: 13px; line-height: 1.7;
    margin-top: 12px; display: none;
  }
  .quiz-feedback.correct { background: #e8f8ed; border: 1px solid #b2dfdb; color: #155724; }
  .quiz-feedback.wrong { background: #fde8ec; border: 1px solid #f5c6cb; color: #721c24; }
  .quiz-feedback.visible { display: block; }
  .quiz-feedback strong { display: block; margin-bottom: 4px; }

  .quiz-nav {
    display: flex; justify-content: flex-end; gap: 10px; margin-top: 16px;
  }
  .btn-next {
    padding: 10px 24px;
    background: var(--indigo); color: white;
    border: none; border-radius: 10px;
    font-weight: 700; font-size: 14px;
    cursor: pointer; font-family: 'Noto Sans JP', sans-serif;
    transition: all 0.2s; display: none;
  }
  .btn-next:hover { background: var(--navy); }
  .btn-next.visible { display: inline-flex; align-items: center; gap: 6px; }

  /* ===== RESULT SCREEN ===== */
  .result-screen {
    text-align: center; padding: 40px 20px; display: none;
  }
  .result-screen.visible { display: block; }
  .result-emoji { font-size: 60px; margin-bottom: 16px; }
  .result-score {
    font-size: 48px; font-weight: 700;
    color: var(--indigo); font-family: 'Poppins', sans-serif;
    margin-bottom: 8px;
  }
  .result-msg { font-size: 16px; color: var(--text-muted); margin-bottom: 24px; }
  .btn-retry {
    padding: 12px 28px;
    background: var(--indigo); color: white;
    border: none; border-radius: 12px;
    font-weight: 700; font-size: 15px;
    cursor: pointer; font-family: 'Noto Sans JP', sans-serif;
    transition: all 0.2s; margin: 0 6px;
  }
  .btn-retry:hover { background: var(--navy); }
  .btn-retry.secondary { background: white; color: var(--indigo); border: 2px solid var(--indigo); }

  /* ===== AI CHECKER ===== */
  .checker-area {
    margin-top: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .app-container { flex-direction: column; padding: 12px; }
    .sidebar { width: 100%; position: static; }
    .sidebar-section { display: flex; flex-wrap: wrap; }
    .sidebar-title { width: 100%; }
    .lesson-btn { width: auto; flex: 1; border-bottom: none; border-right: 1px solid var(--border); border-left: none; border-bottom: 3px solid transparent; }
    .lesson-btn.active { border-bottom-color: var(--indigo); border-left-color: transparent; }
    .tab-btn { font-size: 11px; padding: 10px 6px; }
  }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo">
      <div class="logo-icon">47</div>
      <div>
        <div class="logo-text">英文法マスター</div>
        <div class="logo-sub">Lessons 21–30 | 比較・関係詞・仮定法</div>
      </div>
    </div>
    <div class="header-progress">
      <span id="totalXP" class="xp-badge">0 XP</span>
    </div>
  </div>
</header>

<div class="app-container">
  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-title">📊 比較</div>
      <button class="lesson-btn active" onclick="showLesson('l21')">
        <span class="lesson-num">21</span>比較 (1)
      </button>
      <button class="lesson-btn" onclick="showLesson('l22')">
        <span class="lesson-num">22</span>比較 (2)
      </button>
      <button class="lesson-btn" onclick="showLesson('l23')">
        <span class="lesson-num">23</span>比較 (3)
      </button>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">🔗 関係詞</div>
      <button class="lesson-btn" onclick="showLesson('l24')">
        <span class="lesson-num">24</span>関係詞 (1)
      </button>
      <button class="lesson-btn" onclick="showLesson('l25')">
        <span class="lesson-num">25</span>関係詞 (2)
      </button>
      <button class="lesson-btn" onclick="showLesson('l26')">
        <span class="lesson-num">26</span>関係詞 (3)
      </button>
      <button class="lesson-btn" onclick="showLesson('l27')">
        <span class="lesson-num">27</span>関係詞 (4)
      </button>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">✨ 仮定法</div>
      <button class="lesson-btn" onclick="showLesson('l28')">
        <span class="lesson-num">28</span>仮定法 (1)
      </button>
      <button class="lesson-btn" onclick="showLesson('l29')">
        <span class="lesson-num">29</span>仮定法 (2)
      </button>
      <button class="lesson-btn" onclick="showLesson('l30')">
        <span class="lesson-num">30</span>仮定法 (3)
      </button>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="main-content" id="mainContent"></main>
</div>

<script>
// =============================================
// LESSON DATA
// =============================================
const LESSONS = {
  l21: {
    num: 21, title: "比較 (1)", jp: "原級・比較級",
    color: "#3d52a0",
    desc: "原級（as…as）と比較級（比較級+than）の基本から発展表現まで。",
    sections: [
      {
        title: "A 原級を使った比較 〈as + 原級 + as〉",
        points: [
          { en: "My brother is <span class='key'>as tall as</span> my father.", jp: "私の兄は父と同じくらい背が高い。", note: "as+原級+as〜「〜と同じくらい…だ」" },
          { en: "I don't sing <span class='key'>as well as</span> my sister.", jp: "私は姉ほど上手に歌えない。", note: "not as[so]+原級+as〜「〜ほど…ではない」" },
          { en: "This room is <span class='key'>twice as large as</span> that one.", jp: "この部屋はあの部屋の2倍の大きさだ。", note: "X times as...as〜「〜のX倍…だ」 (2倍=twice, 半分=half)" },
          { en: "Call the doctor <span class='key'>as soon as possible</span>!", jp: "できるだけ早く医師を呼べ！", note: "as...as possible / as...as one can「できるだけ〜」" }
        ],
        formula: "S + V + <span class='accent'>as</span> + 原級 + <span class='accent'>as</span> + 比較対象"
      },
      {
        title: "B 比較級を使った比較 〈比較級 + than〉",
        points: [
          { en: "This stone is <span class='key'>heavier than</span> that one.", jp: "この石はあの石より重い。" },
          { en: "This house is <span class='key'>much[far] larger than</span> mine.", jp: "この家は私の家よりずっと大きい。", note: "差を強調: much / far / even / still + 比較級" },
          { en: "This car is <span class='key'>less expensive than</span> that one.", jp: "この車はあの車より安い。", note: "less+原級+than〜「〜ほど…でない」（= not as...as）" },
        ],
        formula: "S + V + <span class='accent'>比較級</span> + than + 比較対象"
      }
    ]
  },
  l22: {
    num: 22, title: "比較 (2)", jp: "最上級・原級/比較級で最上級の意味",
    color: "#3d52a0",
    desc: "最上級の表現と、原級・比較級を使って最上級の意味を表す方法。",
    sections: [
      {
        title: "A 最上級を使った比較",
        points: [
          { en: "He is <span class='key'>the fastest sprinter</span> in this school.", jp: "彼はこの学校で最も速いスプリンターだ。", note: "in: 範囲の中 / of: 比較相手を個別に意識" },
          { en: "She is <span class='key'>by far[much] the best</span> singer in this country.", jp: "彼女はこの国で群を抜いて最高の歌手だ。", note: "by far / much + 最上級「はるかに/抜群に…」" },
          { en: "This is <span class='key'>one of the nicest rooms</span> in the hotel.", jp: "これはホテルで最も素敵な部屋の1つだ。", note: "one of the + 最上級 + 複数形「最も…な〜の1つ」" },
        ],
        formula: "the + <span class='accent'>最上級</span> + in[of] + 範囲"
      },
      {
        title: "B 原級・比較級で最上級の意味を表す",
        points: [
